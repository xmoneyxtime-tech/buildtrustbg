generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?
  image         String?
  name          String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  reviewReplies ReviewReply[]
  reviewReports ReviewReport[]          @relation("ReviewReportsByUser")
  resolvedReviewReports ReviewReport[]  @relation("ReviewReportsResolvedBy")
  reviewReactions ReviewReaction[]
  reviewModerationLogs ReviewModerationLog[] @relation("ReviewModerationByAdmin")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CompanyApplication {
  id          String            @id @default(cuid())
  slug        String?           @unique
  companyName String
  email       String
  phone       String
  industry    String?
  country     String?
  city        String
  address     String?
  service     String
  website     String?
  description String
  logoUrl     String?
  coverUrl    String?
  isVerified        Boolean @default(false)
  identityVerified  Boolean @default(false)
  phoneVerified     Boolean @default(false)
  portfolioCount    Int     @default(0)
  projectsCount     Int     @default(0)
  reviewsCount      Int     @default(0)
  averageRating     Float   @default(0)
  yearsInBusiness   Int?
  certificatesCount Int     @default(0)
  galleryCount      Int     @default(0)
  responseTimeHours Int?
  activeSubscription Boolean @default(false)
  status      ApplicationStatus @default(PENDING)
  projects    Project[]
  reviews     Review[]
  reviewReplies ReviewReply[]
  verifications Verification[]
  categories  Category[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Category {
  id             String               @id @default(cuid())
  name           String
  description    String
  slug           String               @unique
  icon           String
  image          String?
  featured       Boolean              @default(false)
  popular        Boolean              @default(false)
  premiumOnly    Boolean              @default(false)
  searchKeywords String[]             @default([])
  synonyms       String[]             @default([])
  parentId       String?
  sortOrder      Int                  @default(0)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  parent         Category?            @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]           @relation("CategoryHierarchy")
  companies      CompanyApplication[]
  translations   CategoryTranslation[]

  @@index([parentId])
  @@index([isActive, sortOrder])
}

model CategoryTranslation {
  id              String   @id @default(cuid())
  categoryId      String
  locale          String
  name            String
  description     String
  seoSlug         String
  metaTitle       String
  metaDescription String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale, name])
}

model Project {
  id               String          @id @default(cuid())
  companyId        String
  slug             String          @unique
  title            String
  shortDescription String
  description      String
  category         ProjectCategory
  city             String
  completedAt      DateTime?
  featured         Boolean         @default(false)
  published        Boolean         @default(false)
  status           ProjectStatus   @default(DRAFT)
  images           ProjectImage[]
  reviews          Review[]
  company          CompanyApplication @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([companyId])
  @@index([published])
}

model ProjectImage {
  id       String   @id @default(cuid())
  projectId String
  imageUrl String
  order    Int      @default(0)
  altText  String?
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Verification {
  id          String             @id @default(cuid())
  companyId   String
  type        VerificationType
  status      VerificationStatus @default(PENDING)
  reference   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     CompanyApplication @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reviews     Review[]

  @@index([companyId, status])
}

model Review {
  id              String                 @id @default(cuid())
  companyId       String
  projectId       String
  userId          String
  verificationId  String?
  rating          Int
  title           String
  description     String
  status          ReviewStatus           @default(PENDING)
  verified        Boolean                @default(false)
  isSpam          Boolean                @default(false)
  spamScore       Int                    @default(0)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  approvedAt      DateTime?
  company         CompanyApplication     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project         Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  verification    Verification?          @relation(fields: [verificationId], references: [id], onDelete: SetNull)
  reply           ReviewReply?
  reports         ReviewReport[]
  reactions       ReviewReaction[]
  attachments     ReviewAttachment[]
  moderationLogs  ReviewModerationLog[]

  @@unique([userId, projectId])
  @@index([companyId, status, createdAt])
  @@index([projectId, status])
}

model ReviewReply {
  id          String             @id @default(cuid())
  reviewId    String             @unique
  companyId   String
  userId      String
  content     String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  review      Review             @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  company     CompanyApplication @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

model ReviewReport {
  id            String             @id @default(cuid())
  reviewId       String
  reporterId     String
  resolvedById   String?
  reason         ReviewReportReason
  details        String?
  status         ReviewReportStatus @default(OPEN)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  resolvedAt     DateTime?
  review         Review             @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter       User               @relation("ReviewReportsByUser", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy     User?              @relation("ReviewReportsResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([reviewId, reporterId])
  @@index([status, createdAt])
}

model ReviewReaction {
  id          String            @id @default(cuid())
  reviewId    String
  userId      String
  type        ReviewReactionType
  createdAt   DateTime          @default(now())
  review      Review            @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId, type])
}

model ReviewAttachment {
  id          String   @id @default(cuid())
  reviewId    String
  fileUrl     String
  mimeType    String?
  fileSize    Int?
  altText     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, order])
}

model ReviewModerationLog {
  id          String                 @id @default(cuid())
  reviewId     String
  adminId      String
  action       ReviewModerationAction
  reason       String?
  fromStatus   ReviewStatus?
  toStatus     ReviewStatus
  createdAt    DateTime               @default(now())
  review       Review                 @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  admin        User                   @relation("ReviewModerationByAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([reviewId, createdAt])
  @@index([adminId, createdAt])
}

enum UserRole {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationType {
  COMPANY
  IDENTITY
  PHONE
  DOCUMENT
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectCategory {
  GENERAL
  RESIDENTIAL
  COMMERCIAL
  RENOVATION
  INFRASTRUCTURE
  INTERIOR
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  HIDDEN
  DELETED
}

enum ReviewReportReason {
  SPAM
  ABUSE
  OFF_TOPIC
  FAKE
  CONFLICT_OF_INTEREST
  OTHER
}

enum ReviewReportStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum ReviewReactionType {
  HELPFUL
  NOT_HELPFUL
}

enum ReviewModerationAction {
  APPROVE
  HIDE
  DELETE
  RESTORE
  FLAG
  REPORT_RESOLVED
  REPORT_REJECTED
}
