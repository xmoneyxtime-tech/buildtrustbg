generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?
  image         String?
  name          String?
  role          UserRole  @default(USER)
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CompanyApplication {
  id          String            @id @default(cuid())
  slug        String?           @unique
  companyName String
  email       String
  phone       String
  industry    String?
  country     String?
  city        String
  address     String?
  service     String
  website     String?
  description String
  logoUrl     String?
  coverUrl    String?
  isVerified        Boolean @default(false)
  identityVerified  Boolean @default(false)
  phoneVerified     Boolean @default(false)
  portfolioCount    Int     @default(0)
  projectsCount     Int     @default(0)
  reviewsCount      Int     @default(0)
  averageRating     Float   @default(0)
  yearsInBusiness   Int?
  certificatesCount Int     @default(0)
  galleryCount      Int     @default(0)
  responseTimeHours Int?
  activeSubscription Boolean @default(false)
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}
